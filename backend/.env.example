# Astraeus Backend Example Environment Variables

# Database Configuration
# Default value matches the local docker-compose setup
DATABASE_URL=postgresql://astraeus:astraeus123@localhost:5432/astraeus

# Redis Configuration (for Celery/cache if needed)
REDIS_URL=redis://localhost:6380/0

# MinIO Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=astraeus
MINIO_SECRET_KEY=astraeus12345
MINIO_BUCKET_NAME=astraeus-data

# CORS Allowed Origins (comma separated)
ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173
